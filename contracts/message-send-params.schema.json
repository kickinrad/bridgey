{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "message": {
      "type": "object",
      "properties": {
        "role": {
          "default": "user",
          "type": "string"
        },
        "parts": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "text"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "role",
        "parts"
      ],
      "additionalProperties": false
    },
    "agentName": {
      "default": "anonymous",
      "type": "string",
      "maxLength": 100
    },
    "contextId": {
      "type": "string",
      "maxLength": 200
    }
  },
  "required": [
    "message",
    "agentName"
  ],
  "additionalProperties": false
}
