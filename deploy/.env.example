# Bridgey Persona Deployment - Environment Variables
# Copy to .env and fill in real values

# Bearer tokens for A2A authentication
# Generate with: node -e "console.log('brg_' + require('crypto').randomBytes(32).toString('hex'))"
BRIDGEY_TOKEN_JULIA=brg_generate_me
BRIDGEY_TOKEN_MILA=brg_generate_me
BRIDGEY_TOKEN_BOB=brg_generate_me
BRIDGEY_TOKEN_NARA=brg_generate_me
BRIDGEY_TOKEN_WARREN=brg_generate_me

# Discord bot tokens (optional — only needed for bridgey-discord service)
DISCORD_BOT_JULIA=
DISCORD_BOT_MILA=
