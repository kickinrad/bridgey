{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/daemon/dist/watchdog.js --config ${CLAUDE_PLUGIN_ROOT}/bridgey.config.json --pidfile /tmp/bridgey-${USER}.pid",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
