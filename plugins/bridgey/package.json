{
  "name": "bridgey",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsx esbuild.config.ts",
    "build:tsc": "npm run build:daemon && npm run build:server",
    "build:daemon": "cd daemon && npx tsc",
    "build:server": "cd server && npx tsc",
    "install:all": "cd daemon && npm install && cd ../server && npm install",
    "test": "cd daemon && npm test",
    "test:daemon": "cd daemon && npm test"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "tsx": "^4.21.0"
  }
}
